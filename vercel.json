{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "web",
  "functions": {
    "api/health.py": {
      "runtime": "@vercel/python@4.3.1",
      "includeFiles": "{models,utils}/**"
    },
    "api/auto-arrange.py": {
      "runtime": "@vercel/python@4.3.1",
      "includeFiles": "{models,utils}/**"
    },
    "api/evaluate.py": {
      "runtime": "@vercel/python@4.3.1",
      "includeFiles": "{models,utils}/**"
    },
    "api/export-pdf.py": {
      "runtime": "@vercel/python@4.3.1",
      "includeFiles": "{models,utils}/**"
    },
    "api/export-xlsx.py": {
      "runtime": "@vercel/python@4.3.1",
      "includeFiles": "{models,utils}/**"
    }
  },
  "rewrites": [
    { "source": "/api/export/pdf", "destination": "/api/export-pdf" },
    { "source": "/api/export/xlsx", "destination": "/api/export-xlsx" }
  ]
}
