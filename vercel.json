{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/health.py": { "includeFiles": "{models,utils}/**" },
    "api/auto-arrange.py": { "includeFiles": "{models,utils}/**" },
    "api/evaluate.py": { "includeFiles": "{models,utils}/**" },
    "api/export/pdf.py": { "includeFiles": "{models,utils}/**" },
    "api/export/xlsx.py": { "includeFiles": "{models,utils}/**" }
  },
  "rewrites": [
    { "source": "/", "destination": "/web/index.html" },
    { "source": "/web", "destination": "/web/index.html" },
    { "source": "/web/", "destination": "/web/index.html" }
  ]
}
